# Postgres connection string used by Drizzle and Better Auth
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm

# Port the Express server listens on
PORT=3000

# Secret used by Better Auth to sign session cookies/tokens (use a long random string)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Base URL of this backend (used by Better Auth for cookie/origin handling)
BETTER_AUTH_URL=http://localhost:3000

# Origin of the Angular dev server, allowed for CORS with credentials
CORS_ORIGIN=http://localhost:4200

# development | production
NODE_ENV=development
